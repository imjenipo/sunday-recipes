// Status popover component
function StatusPicker({ currentStatus, onChange, above = false }) {
  const [open, setOpen] = useState(false);
  const ref = useRef();
  const st = STATUSES.find(s => s.id === currentStatus) || STATUSES[0];

  useEffect(() => {
    if (!open) return;
    function handler(e) { if (ref.current && !ref.current.contains(e.target)) setOpen(false); }
    document.addEventListener("mousedown", handler);
    return () => document.removeEventListener("mousedown", handler);
  }, [open]);

  return (
    <div className="rb-status-wrap" ref={ref}>
      <span
        className="rb-status-badge"
        style={{ background: st.color + "20", color: st.color, cursor: "pointer", padding: above ? "5px 14px" : "3px 9px", fontSize: above ? "0.82rem" : "0.7rem" }}
        onClick={e => { e.stopPropagation(); setOpen(o => !o); }}
        title="Mudar status"
      >
        {st.label} <ChevronDown size={12} style={{ opacity: 0.6, flexShrink: 0 }} />
      </span>
      {open && (
        <div className="rb-status-popover" style={above ? { bottom: "calc(100% + 6px)" } : { bottom: "auto", top: "calc(100% + 6px)" }}>
          {STATUSES.map(s => (
            <div key={s.id} className={`rb-sp-option ${s.id === currentStatus ? "active" : ""}`}
              onClick={e => { e.stopPropagation(); onChange(s.id); setOpen(false); }}>
              <span className="rb-sp-dot" style={{ background: s.color }} />
              {s.label}
              {s.id === currentStatus && <Check size={13} style={{ marginLeft: "auto", color: s.color }} />}
            </div>
          ))}
        </div>
      )}
    </div>
  );
}

export default function RecipeBook() {
  const [tab, setTab] = useState("add");
  const [recipes, setRecipes] = useState(loadRecipes);
  const [detailId, setDetailId] = useState(null);
  const [showPrivacy, setShowPrivacy] = useState(false);
  const [filterCat, setFilterCat] = useState("all");
  const [filterFav, setFilterFav] = useState(false);
  const [filterStatus, setFilterStatus] = useState("all");
  const [confirmDelete, setConfirmDelete] = useState(null); // card-level confirm
  const [detailConfirmDelete, setDetailConfirmDelete] = useState(false); // detail-level confirm
  const [toast, setToast] = useState(null);
  const [undoData, setUndoData] = useState(null);
  const [checked, setChecked] = useState({});

  // Edit mode
  const [editMode, setEditMode] = useState(false);
  const [editDraft, setEditDraft] = useState(null);

  // Add form
  const [name, setName] = useState("");
  const [url, setUrl] = useState("");
  const [category, setCategory] = useState("");
  const [status, setStatus] = useState("quero");
  const [photo, setPhoto] = useState(null);
  const [photoPreview, setPhotoPreview] = useState(null);
  const [extracting, setExtracting] = useState(false);
  const [extracted, setExtracted] = useState(null);
  const fileRef = useRef();
  const urlTimer = useRef();

  useEffect(() => { saveRecipes(recipes); }, [recipes]);

  // Close card confirm on outside click
  useEffect(() => {
    if (!confirmDelete) return;
    function handler() { setConfirmDelete(null); }
    document.addEventListener("mousedown", handler);
    return () => document.removeEventListener("mousedown", handler);
  }, [confirmDelete]);

  function showToast(msg, undo) {
    setToast(msg);
    setUndoData(undo || null);
    setTimeout(() => { setToast(null); setUndoData(null); }, 4000);
  }

  function handleUrlChange(e) {
    const val = e.target.value;
    setUrl(val);
    setExtracted(null);
    clearTimeout(urlTimer.current);
    if (val.startsWith("http")) {
      urlTimer.current = setTimeout(async () => {
        setExtracting(true);
        try {
          const result = await extractRecipeFromUrl(val);
          if (result && result.title) {
            setExtracted(result);
            if (!name.trim()) setName(result.title);
          }
        } catch (err) { console.error(err); }
        setExtracting(false);
      }, 1200);
    }
  }

  function handlePhotoChange(e) {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = ev => { setPhoto(ev.target.result); setPhotoPreview(ev.target.result); };
    reader.readAsDataURL(file);
  }

  function handleAddRecipe() {
    if (!name.trim()) return;
    const recipe = {
      id: Date.now().toString(),
      name: name.trim(), url: url.trim(), category, status, photo,
      favorite: false,
      createdAt: new Date().toLocaleDateString("pt-BR", { day: "numeric", month: "short", year: "numeric" }),
      ingredients: extracted?.ingredients || [],
      steps: extracted?.steps || [],
      notes: "",
    };
    setRecipes(prev => [recipe, ...prev]);
    resetForm();
    setTab("my");
    showToast("Recipe added! 🎉");
  }

  function resetForm() {
    setName(""); setUrl(""); setCategory(""); setStatus("quero");
    setPhoto(null); setPhotoPreview(null); setExtracted(null); setExtracting(false);
  }

  function handleDelete(id) {
    const recipe = recipes.find(r => r.id === id);
    const index = recipes.indexOf(recipe);
    setRecipes(prev => prev.filter(r => r.id !== id));
    setConfirmDelete(null);
    setDetailId(null);
    setDetailConfirmDelete(false);
    showToast("Recipe removed.", { recipe, index });
  }

  function handleUndo() {
    if (!undoData) return;
    setRecipes(prev => { const a = [...prev]; a.splice(undoData.index, 0, undoData.recipe); return a; });
    setToast(null); setUndoData(null);
  }

  function toggleFav(id) {
    setRecipes(prev => prev.map(r => r.id === id ? { ...r, favorite: !r.favorite } : r));
  }

  function setStatusFor(id, newStatus) {
    setRecipes(prev => prev.map(r => r.id !== id ? r : { ...r, status: newStatus }));
  }

  function updateNotes(id, notes) {
    setRecipes(prev => prev.map(r => r.id === id ? { ...r, notes } : r));
  }

  function startEdit(r) {
    setEditDraft({
      name: r.name,
      ingredients: [...(r.ingredients || [])],
      steps: [...(r.steps || [])],
    });
    setEditMode(true);
    setDetailConfirmDelete(false);
  }

  function cancelEdit() { setEditMode(false); setEditDraft(null); }

  function saveEdit(id) {
    setRecipes(prev => prev.map(r => r.id !== id ? r : {
      ...r,
      name: editDraft.name.trim() || r.name,
      ingredients: editDraft.ingredients.filter(s => s.trim()),
      steps: editDraft.steps.filter(s => s.trim()),
    }));
    setEditMode(false);
    setEditDraft(null);
    showToast("Recipe updated! ✓");
  }

  function draftSetIng(i, val) {
    setEditDraft(d => { const arr = [...d.ingredients]; arr[i] = val; return { ...d, ingredients: arr }; });
  }
  function draftAddIng() {
    setEditDraft(d => ({ ...d, ingredients: [...d.ingredients, ""] }));
  }
  function draftRemoveIng(i) {
    setEditDraft(d => ({ ...d, ingredients: d.ingredients.filter((_, idx) => idx !== i) }));
  }
  function draftSetStep(i, val) {
    setEditDraft(d => { const arr = [...d.steps]; arr[i] = val; return { ...d, steps: arr }; });
  }
  function draftAddStep() {
    setEditDraft(d => ({ ...d, steps: [...d.steps, ""] }));
  }
  function draftRemoveStep(i) {
    setEditDraft(d => ({ ...d, steps: d.steps.filter((_, idx) => idx !== i) }));
  }

  const catLabel = id => CATEGORIES.find(c => c.id === id)?.label || "";
  const statusObj = id => STATUSES.find(s => s.id === id) || STATUSES[0];
  const filtered = recipes.filter(r => {
    if (filterFav && !r.favorite) return false;
    if (filterCat !== "all" && r.category !== filterCat) return false;
    if (filterStatus !== "all" && r.status !== filterStatus) return false;
    return true;
  });

  const Toast = () => toast ? (
    <div className="rb-toast">
      {toast}
      {undoData && <button className="rb-undo" onClick={handleUndo}>Undo</button>}
    </div>
