            <button className={`rb-tab ${tab === "add" ? "active" : ""}`} onClick={() => setTab("add")}>Add Recipe</button>
            <button className={`rb-tab ${tab === "my" ? "active" : ""}`} onClick={() => setTab("my")}>
              My Recipes {recipes.length > 0 && <span className="rb-count">{recipes.length}</span>}
            </button>
          </div>
        </div>
        {/* ── ADD TAB ── */}
        {tab === "add" && (
          <div className="rb-card">
            <div className="rb-card-hero">
              <div className="icon" style={{ display: "flex", justifyContent: "center" }}><img src={RECIPE_ICON} alt="" style={{ width: 64, height: 64, objectFit: "contain" }} /></div>
              <h1>Sunday <em>Recipes</em></h1>
              <p>Paste a link and the recipe is extracted automatically 🍴</p>
            </div>

            {/* NAME FIRST */}
            <div className="rb-field">
              <label className="rb-label">Recipe name *</label>
              <input className="rb-input" placeholder="Recipe name" value={name} onChange={e => setName(e.target.value)} />
            </div>

            {/* URL SECOND */}
            <div className="rb-field">
              <label className="rb-label">Recipe URL <span style={{ color: "#bbb", textTransform: "none", fontSize: "0.75rem" }}>(paste to extract automatically)</span></label>
              <div className="rb-url-row">
                <input className="rb-input" placeholder="https://example.com/recipe" value={url} onChange={handleUrlChange}
                  style={{ paddingRight: extracting ? 140 : extracted ? 110 : 14 }} />
                {extracting && <span className="rb-url-status" style={{ color: "#e85d3d" }}><span className="rb-spinner" /> Extracting...</span>}
                {extracted && !extracting && <span className="rb-url-status" style={{ color: "#22c55e", display: "flex", alignItems: "center", gap: 4 }}><Check size={14} /> Extracted!</span>}
              </div>
              {extracting && (
                <div className="rb-extracting-box">
                  <div className="rb-spinner" />
                  Claude is searching for ingredients and steps...
                </div>
              )}
              {extracted && !extracting && (
                <div className="rb-extracted-ok">
                  <h4 style={{ display: "flex", alignItems: "center", gap: 5 }}><Check size={13} /> {extracted.ingredients.length} ingredientes · {extracted.steps.length} passos encontrados</h4>
                  <ul>
                    {extracted.ingredients.slice(0, 3).map((ing, i) => <li key={i}>{ing}</li>)}
                    {extracted.ingredients.length > 3 && <li>+{extracted.ingredients.length - 3} mais...</li>}
                  </ul>
                </div>
              )}
            </div>

            <div className="rb-field">
              <label className="rb-label">Category</label>
              <div className="rb-pills">
                {CATEGORIES.map(c => (
                  <button key={c.id} className={`rb-pill ${category === c.id ? "selected" : ""}`}
                    onClick={() => setCategory(category === c.id ? "" : c.id)}>{c.label}</button>
                ))}
              </div>
            </div>

            <div className="rb-field">
              <label className="rb-label">Status</label>
              <div style={{ display: "flex", gap: "0.5rem", flexWrap: "wrap" }}>
                {STATUSES.map(s => (
                  <button key={s.id} className="rb-status-pill"
                    style={status === s.id ? { borderColor: s.color, background: s.color + "18", color: s.color, fontWeight: 500 } : {}}
                    onClick={() => setStatus(s.id)}>{s.label}</button>
                ))}
              </div>
            </div>

            <div className="rb-field">
              <label className="rb-label">Cover photo <span style={{ color: "#bbb", textTransform: "none" }}>(optional)</span></label>
              <div className="rb-photo-area" onClick={() => fileRef.current.click()}>
                {photoPreview
                  ? <img src={photoPreview} alt="preview" className="rb-photo-preview" />
                  : <><div style={{ marginBottom: "0.5rem", display: "flex", justifyContent: "center", color: "#bbb" }}><Image size={28} strokeWidth={1.5} /></div>
                    <p style={{ fontFamily: "'DM Sans',sans-serif", fontSize: "0.83rem", color: "#aaa" }}>Click to add a photo</p></>}
              </div>
              <input ref={fileRef} type="file" accept="image/*" style={{ display: "none" }} onChange={handlePhotoChange} />
              {photoPreview && (
                <button style={{ marginTop: "0.5rem", background: "none", border: "none", color: "#aaa", fontFamily: "'DM Sans',sans-serif", fontSize: "0.8rem", cursor: "pointer" }}
                  onClick={() => { setPhoto(null); setPhotoPreview(null); }}><X size={13} style={{ display: "inline", verticalAlign: "middle" }} /> Remover foto</button>
              )}
            </div>

            <button className="rb-btn-primary" onClick={handleAddRecipe} disabled={!name.trim()}>Add Recipe</button>
            {(name || url || category || photo) && (
              <button className="rb-btn-secondary" onClick={resetForm}>Cancel</button>
            )}
          </div>
        )}

        {/* ── MY RECIPES ── */}
        {tab === "my" && (
          <div>
            <div className="rb-my-header">
              <h2 className="rb-my-title">My Recipes</h2>
              <button className={`rb-filter-pill ${filterFav ? "active" : ""}`} onClick={() => setFilterFav(f => !f)} style={{ display: "flex", alignItems: "center", gap: "5px" }}><Heart size={13} fill={filterFav ? "currentColor" : "none"} /> Favorites</button>
            </div>
            <div className="rb-filter-bar">
              <button className={`rb-filter-pill ${filterCat === "all" ? "active" : ""}`} onClick={() => setFilterCat("all")}>All</button>
              {CATEGORIES.filter(c => recipes.some(r => r.category === c.id)).map(c => (
                <button key={c.id} className={`rb-filter-pill ${filterCat === c.id ? "active" : ""}`}
                  onClick={() => setFilterCat(filterCat === c.id ? "all" : c.id)}>{c.label}</button>
              ))}
              <div style={{ marginLeft: "auto", display: "flex", gap: "0.4rem" }}>
                {STATUSES.map(s => (
                  <button key={s.id} className="rb-filter-pill"
                    style={filterStatus === s.id ? { background: s.color, borderColor: s.color, color: "white" } : {}}
                    onClick={() => setFilterStatus(filterStatus === s.id ? "all" : s.id)}>{s.label}</button>
                ))}
              </div>
            </div>

            {filtered.length === 0 ? (
              <div className="rb-empty">
                <div className="e-icon" style={{ display: "flex", justifyContent: "center", color: "#ccc" }}>{recipes.length === 0 ? <BookOpen size={48} strokeWidth={1.5} /> : <Search size={48} strokeWidth={1.5} />}</div>
                <p>{recipes.length === 0 ? "Your book is empty. Add your first recipe!" : "No recipes match these filters."}</p>
                {recipes.length === 0 && (
                  <button className="rb-btn-primary" style={{ maxWidth: 200, margin: "1rem auto 0" }} onClick={() => setTab("add")}>
                    Adicionar receita
                  </button>
                )}
              </div>
            ) : (
              <div className="rb-grid">
                {filtered.map(r => {
                  const ph = getPlaceholder(r.id);
                  const isConfirming = confirmDelete === r.id;
                  return (
                    <div key={r.id} className={`rb-recipe-card ${isConfirming ? "confirming" : ""}`}
                      onClick={() => { if (!isConfirming) { setDetailId(r.id); setChecked({}); } }}>

                      {/* FAV + DELETE buttons */}
                      {!isConfirming && (
                        <>
                          <button className={`rb-fav-btn ${r.favorite ? "active" : ""}`}
                            onClick={e => { e.stopPropagation(); toggleFav(r.id); }}>
                            <Heart size={15} fill={r.favorite ? "currentColor" : "none"} />
                          </button>
                          <button className="rb-del-btn"
                            onClick={e => { e.stopPropagation(); setConfirmDelete(r.id); }}
                            title="Remove"><X size={14} /></button>
                        </>
                      )}

                      <div className="rb-recipe-thumb" style={{ background: ph.bg }}>
                        {r.photo ? <img src={r.photo} alt={r.name} /> : ph.emoji}
                      </div>

                      <div className="rb-recipe-body">
                        <div className="rb-recipe-name">{r.name}</div>
                        <div className="rb-recipe-meta">
                          {r.createdAt}{r.category ? ` · ${catLabel(r.category)}` : ""}
                          {r.ingredients?.length > 0 && ` · ${r.ingredients.length} ing.`}
                        </div>
                        <div className="rb-recipe-footer">
                          {r.url && !isConfirming
                            ? <a href={r.url} target="_blank" rel="noopener noreferrer" className="rb-goto" onClick={e => e.stopPropagation()} style={{ display: "flex", alignItems: "center", gap: "3px" }}>Go to site <ExternalLink size={12} /></a>
                            : <span />}
                          {!isConfirming && (
                            <div onClick={e => e.stopPropagation()}>
                              <StatusPicker currentStatus={r.status} onChange={s => setStatusFor(r.id, s)} />
                            </div>
                          )}
                        </div>
                      </div>

                      {/* INLINE DELETE CONFIRM — overlay inside card */}
                      {isConfirming && (
                        <div className="rb-delete-confirm" onClick={e => e.stopPropagation()}>
                          <p><strong>{r.name}</strong>Remove from book?</p>
                          <div className="rb-dc-btns">
                            <button className="rb-dc-no" onClick={e => { e.stopPropagation(); setConfirmDelete(null); }}>Cancel</button>
                            <button className="rb-dc-yes" onClick={e => { e.stopPropagation(); handleDelete(r.id); }}>Remove</button>
                          </div>
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            )}
          </div>
        )}
      </main>

      <Footer />
      <Toast />
    </div>
  );
}