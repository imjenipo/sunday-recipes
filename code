  const detailRecipe = detailId ? recipes.find(r => r.id === detailId) : null;

  const Footer = () => (
    <footer className="rb-footer">
      <span>© {new Date().getFullYear()} Created to Create by Castro</span>
      <button onClick={() => { setShowPrivacy(true); setDetailId(null); }}
