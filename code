          </p>
        </main>
        <Footer />
      </div>
    );
  }

  // ─── DETAIL PAGE ───
  if (detailRecipe) {
    const r = detailRecipe;
    const ph = getPlaceholder(r.id);
    return (
      <div style={{ minHeight: "100vh", background: "#f0ece4" }}>
        <style>{CSS}</style>
        <div className="rb-linen-bg" />
