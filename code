        Privacy Policy
      </button>
    </footer>
  );

  // ─── PRIVACY PAGE ───
  if (showPrivacy) {
    return (
      <div style={{ minHeight: "100vh", background: "#f0ece4" }}>
        <style>{CSS}</style>
        <div className="rb-linen-bg" />
        <header className="rb-header rb-linen-header">
          <div className="rb-logo" onClick={() => setShowPrivacy(false)}><strong>Sunday</strong><em>Recipes</em></div>
        </header>
        <main className="rb-privacy-main">
          <button className="rb-privacy-back" onClick={() => setShowPrivacy(false)}>
